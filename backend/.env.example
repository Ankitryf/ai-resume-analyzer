# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_resume_analyzer
# API Keys
GEMINI_API_KEY=replace_with_your-gemini-api-key

# JWT Configuration
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                          # REQUIRED — must be 32+ chars, not a placeholder
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=False
APP_NAME=AI Resume Analyzer
MAX_FILE_SIZE=10485760

# NLP Configuration
SPACY_MODEL=en_core_web_sm

# Upload Directory
UPLOAD_DIR=uploads

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://yourdomain.com"]
